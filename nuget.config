<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <add key="ignoreFailedSources" value="true" />
    <!-- Repo-local global packages folder (relative to this nuget.config).
         Restore auto-populates it from the sources below; offline builds then
         resolve from it with no extra steps. -->
    <add key="globalPackagesFolder" value="local-packages" />
  </config>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- IGT internal packages (IGT.FloorNet.*). Requires the corporate network. -->
    <add key="IGT.Systems.Nexus" value="https://nexus.tools.igt.com/repository/nuget-group/index.json" />
  </packageSources>
</configuration>
